# Environment Variables Example
# Copy this file to .env and fill in your own values

# Enable debug mode
VITE_DEBUG=true

# ImgBB API Key for image uploads (Required for screenshot feature)
# Get your free API key at: https://api.imgbb.com/
# 1. Create a free account (no credit card required)
# 2. Get your API key
# 3. Add it below for local development
# 4. For Vercel deployment: Add this as an environment variable in Vercel dashboard
#    (Settings > Environment Variables > VITE_IMGBB_API_KEY)
VITE_IMGBB_API_KEY=your_imgbb_api_key_here
